# Backend URL the app uses for OCR, translate, and nearby.
# Copy this file to .env and change if needed.
#
# - App and backend on the SAME PC (Expo web / emulator):
#   Use default (no need to set) or:
#   EXPO_PUBLIC_BACKEND_URL=http://localhost:5000
#
# - App on PHONE or another PC (backend on this machine):
#   Set to this PC's IP so the device can reach the backend, e.g.:
#   EXPO_PUBLIC_BACKEND_URL=http://192.168.1.100:5000
#   Find IP: Windows: ipconfig | Mac/Linux: ifconfig or ip addr

# EXPO_PUBLIC_BACKEND_URL=http://localhost:5000
